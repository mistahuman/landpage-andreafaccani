---
import { Send, Mail, Phone, CalendarClock } from "@lucide/svelte";
---
<section class="section-shell">
  <div class="section-heading space-y-4">
    <h2 class="section-title">Prenota una valutazione</h2>
    <p class="section-copy">
      Contattami per valutare al meglio il tuo caso.
    </p>
  </div>

  <div class="mx-auto max-w-5xl space-y-4">

    <div class="grid gap-3 md:grid-cols-3">
      <a class="feature-card contact-card flex items-center justify-between gap-4 !p-5 text-left" href="tel:+393335694767" type="button">
        <div>
          <p class="text-sm uppercase tracking-[0.18em] opacity-60">Telefono</p>
          <p class="mt-1 text-lg font-semibold">Chiama ora</p>
          <p class="mt-1 text-sm opacity-70">Per un confronto rapido sul tuo caso.</p>
        </div>
        <Phone size={22} />
      </a>

      <a class="feature-card contact-card flex items-center justify-between gap-4 !p-5 text-left" href="https://wa.me/+393335694767" type="button">
        <div>
          <p class="text-sm uppercase tracking-[0.18em] opacity-60">WhatsApp</p>
          <p class="mt-1 text-lg font-semibold">Scrivi per prenotare</p>
          <p class="mt-1 text-sm opacity-70">Il canale piu semplice per fissare la valutazione.</p>
        </div>
        <Send size={22} />
      </a>

      <a
        href="mailto:andrea.faccani3@gmail.com"
        target="_blank"
        type="button"
        class="feature-card contact-card flex items-center justify-between gap-4 !p-5 text-left"
      >
        <div>
          <p class="text-sm uppercase tracking-[0.18em] opacity-60">Email</p>
          <p class="mt-1 text-lg font-semibold">andrea.faccani3@gmail.com</p>
          <p class="mt-1 text-sm opacity-70">Utile se vuoi spiegare meglio la situazione.</p>
        </div>
        <Mail size={22} />
      </a>
    </div>
  </div>
</section>
