---
import {
  HeartPulse,
  Hand,
  Activity,
  Accessibility,
  StretchHorizontal,
} from "@lucide/svelte";

const services = [
  {
    title: "Riabilitazione Post-Operatoria",
    description:
      "Recupero funzionale post trauma e interventi chirurgici (spalla, ginocchio, anca, colonna vertebrale).",
    icon: HeartPulse,
    imgSrc: "post-op1.jpeg",
  },
  {
    title: "Trattamento del dolore cronico e aspecifico",
    description:
      "Utilizzo un approccio biopsicosociale basato su educazione e attivazione (mal di schiena, cervicalgia, tendinopatie). Aiuto il paziente a capire il dolore e a tornare a muoversi in modo graduale e mirato, indicato per mal di schiena, cervicalgia e tendinopatie.",
    icon: Hand,
    imgSrc: "spec-dolore-aspecifico.jpeg",
  },
  {
    title: "Fisioterapia per disturbi dell'equilibrio",
    description: "Valutazione per distinguere l'origine vestibolare, visiva, propriocettiva o centrale e impostare un lavoro mirato sul recupero delle funzioni deficitarie.",
    icon: Accessibility,
    imgSrc: "dist-equilib.jpeg",
  },
  {
    title: "Terapia manuale e trattamento miofasciale",
    description: "Utilizzo tecniche mirate alla riduzione del dolore, tensione muscolare e della rigidità articolare, migliorando il movimento e preparando il corpo al recupero attivo.",
    icon: Activity,
    imgSrc: "ter-man.jpeg",
  },
  {
    title: "Esercizio terapeutico personalizzato",
    description: "Il cuore del percorso riabilitativo! Permette di recuperare la mobilità e forza muscolare, riducendo dolore e ottenendo risultati duraturi. Fondamentale per consolidare benefici delle terapie passive e prevenire ricadute.",
    icon: StretchHorizontal,
    imgSrc: "es-tera.jpeg",
  },
];
---
<section class="section-shell">
  <div class="section-heading space-y-4">
      <h2 class="section-title">Trattamenti mirati, costruiti sul tuo caso reale.</h2>
      <p class="section-copy">
        Ogni percorso parte da una valutazione iniziale e si sviluppa con trattamenti ed esercizi coerenti con obiettivi, tempi e contesto della persona.
      </p>
    <p class="mx-auto max-w-2xl text-sm opacity-70">
      Il focus non è solo ridurre il dolore, ma recuperare autonomia, movimento e qualità di vita.
    </p>
  </div>

  <div class="grid grid-cols-1 gap-6 md:grid-cols-2 xl:grid-cols-3">
    {services.map(({ title, description, icon: Icon, imgSrc }) => (
      <article class="feature-card overflow-hidden !p-0">
        <img src={imgSrc} class="h-56 w-full object-cover" alt={title} loading="lazy" />
        <div class="space-y-4 p-5">
          <div class="flex items-start gap-4">
            <div class="rounded-2xl bg-primary-500/12 p-3 text-primary-700">
              <Icon size={24} />
            </div>
            <div>
              <h3 class="text-xl font-bold leading-tight">{title}</h3>
            </div>
          </div>
          <p class="text-sm leading-7 opacity-80">{description}</p>
        </div>
      </article>
    ))}
  </div>
</section>
