---
import { Home, SlidersHorizontal, BadgeCheck } from "@lucide/svelte";

const problems = [
  {
    icon: Home,
    title: "Comodità e flessibilità",
    description: "Ricevi il trattamento direttamente a casa tua o nei centri medici nei quali collaboro."
  },
  {
    icon: SlidersHorizontal,
    title: "Percorsi personalizzati",
    description: "Programmi di riabilitazione su misura per le tue esigenze specifiche."
  },
  {
    icon: BadgeCheck,
    title: "Trattamenti efficaci",
    description: "Trattamenti basati sulle più recenti evidenze scientifiche e linee guida."
  }
];
---
<section class="section-shell">
  <div class="mb-10 text-center">
    <h2 class="section-title mb-4">Perché scegliere la fisioterapia con me</h2>
    <p class="section-copy mx-auto">
      Ogni problema fisico richiede una valutazione precisa e un percorso coerente. Il mio approccio mette al centro la persona, non solo il sintomo.
    </p>
  </div>

  <div class="grid grid-cols-1 gap-6 md:grid-cols-3">
    {problems.map(({ icon: Icon, title, description }) => (
      <div class="feature-card text-center">
        <div class="hero-highlight-icon mx-auto mb-4">
          <Icon size={22} class="text-primary-700" />
        </div>
        <h3 class="text-xl font-bold mb-2">{title}</h3>
        <p class="leading-7 opacity-75">{description}</p>
      </div>
    ))}
  </div>
</section>
