---
import Lightswitch from "@components/generic/Lightswitch.astro";
import { Phone, Mail } from "@lucide/svelte";
---

<header
	class="sticky top-0 z-50 flex h-[76px] w-full items-center border-b border-surface-500/15 bg-surface-50/80 backdrop-blur-xl dark:bg-surface-950/80"
>
	<div
		class="container mx-auto grid max-w-screen-2xl grid-cols-[auto_1fr_auto] items-center gap-4 px-4 md:px-8"
	>
		<div class="flex items-center gap-3">
			<a class="inline-flex items-center justify-center rounded-xl border border-surface-200-800 bg-surface-50-950 p-2" href="/" title="Andrea Faccani">
				<img class="site-logo" src="favicon1.svg" alt="Andrea Faccani logo" width="28" height="28" />
			</a>
			<div>
				<p class="font-bold leading-none">Andrea Faccani</p>
				<p class="hidden text-sm opacity-65 md:block">Fisioterapia a domicilio a Lugo e dintorni</p>
			</div>
		</div>

		<nav class="hidden items-center justify-center gap-6 md:flex">
			<a class="header-link" href="#servizi">Servizi</a>
			<a class="header-link" href="#contatti">Contatti</a>
		</nav>

		<div class="flex justify-end items-center gap-2">
			<Lightswitch />
			<a class="hidden rounded-lg px-4 py-2 text-sm font-medium transition hover:bg-primary-500/10 md:inline-flex" href="mailto:andrea.faccani3@gmail.com">
				<Mail size={18} />
			</a>
			<a class="btn preset-filled-primary-500 !px-4 !py-2 text-sm" href="tel:+393335694767">
				<Phone size={18} />
				<span class="hidden sm:inline">Chiama ora</span>
			</a>
		</div>
	</div>
</header>
